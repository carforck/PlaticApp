# ─────────────────────────────────────────────
#  PlaticApp — variables de entorno (ejemplo)
#  Copia este archivo a .env.local y rellena los valores.
#  NUNCA subas el .env real al repo.
# ─────────────────────────────────────────────

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key   # solo backend / edge functions

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-token-de-BotFather
TELEGRAM_WEBHOOK_SECRET=una-cadena-aleatoria-larga   # valida que el webhook venga de Telegram

# --- IA: Google Gemini (texto + imágenes) ---
GEMINI_API_KEY=tu-api-key-de-google-ai-studio
GEMINI_MODEL=gemini-2.5-flash

# --- IA: Groq (transcripción de audio con Whisper) ---
GROQ_API_KEY=tu-api-key-de-groq
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# --- App ---
APP_TIMEZONE=America/Bogota
APP_DEFAULT_CURRENCY=COP
